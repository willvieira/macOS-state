# user.config.toml — Copy this file to user.config.toml and fill in your details.
# user.config.toml is gitignored and will not be committed.

[git]
name        = "Your Name"
email       = "you@example.com"
signing_key = ""          # GPG key fingerprint, leave empty to skip

[modules]
homebrew        = true
macos           = true
dev             = true
r               = false   # Set true if you use R
python          = false   # Set true if you use Python
terminal        = false   # Set true to install Oh My Zsh and Powerlevel10k
vscode          = false   # Set true to install VS Code and base extensions
productivity    = false   # Set true to install GUI productivity apps
dotfiles        = false   # Set true to symlink config files
local_bin       = false   # Set true to snapshot ~/.local/bin, ~/bin, and similar user tools
manual_apps     = false   # Set true to snapshot apps that likely need manual installation
ai_agents       = false   # Set true to configure Claude Code plugins from profiles/ai/agents.Brewfile
browser         = false   # Brave, Chrome, Firefox — auto-detected
node            = false   # Set true to install Node and pnpm
vscode_themes   = false   # Set true to install optional VS Code themes
iterm2          = false   # Set true if you use iTerm2
raycast         = false   # Set true if you use Raycast
alfred          = false   # Set true if you use Alfred
bettertouchtool = false   # Set true if you use BetterTouchTool

[snapshots]
path = ""                # Empty = iCloud Drive if available, otherwise local Application Support

[macos.display]
display_sleep = 10        # Minutes before display sleeps (0 = never)
idle_timeout  = 30        # Minutes before system sleeps (0 = never)

[macos.browser]
default = ""              # brave | chrome | firefox | safari | "" (skip)

[macos.dock]
autohide     = true
show_recents = false
tilesize     = 48

[macos.finder]
show_pathbar         = true
show_status_bar      = true
preferred_view_style = "Nlsv" # icnv | Nlsv | clmv | Flwv
default_search_scope = "SCcf" # SCcf = current folder
show_all_files       = true
show_all_extensions  = true

[macos.keyboard]
key_repeat             = 2
initial_key_repeat     = 15
press_and_hold_enabled = true

[macos.trackpad]
clicking     = true
tap_to_click = 1

[macos.screenshots]
location       = "$HOME/Desktop"
type           = "png"
disable_shadow = true

[macos.appearance]
style = "Auto"            # Auto | Dark | Light
