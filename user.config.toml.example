# user.config.toml — Copy this file to user.config.toml and fill in your details.
# user.config.toml is gitignored and will not be committed.

[git]
name        = "Your Name"
email       = "you@example.com"
signing_key = ""          # GPG key fingerprint, leave empty to skip

[modules]
homebrew = true
macos    = true
dev      = true
r        = false          # Set true if you use R
python   = false          # Set true if you use Python
terminal = true
dotfiles = true
claude   = true
browser         = true    # Brave, Chrome, Firefox — auto-detected
iterm2          = false   # Set true if you use iTerm2
raycast         = false   # Set true if you use Raycast
alfred          = false   # Set true if you use Alfred
bettertouchtool = false   # Set true if you use BetterTouchTool

[macos]
display_sleep   = 10      # Minutes before display sleeps (0 = never)
idle_timeout    = 30      # Minutes before system sleeps (0 = never)
default_browser = "brave" # brave | chrome | firefox | safari | "" (skip)

# Dock
dock_autohide     = true
dock_show_recents = false
dock_tilesize     = 48

# Finder
finder_show_pathbar        = true
finder_show_status_bar     = true
finder_preferred_view_style = "Nlsv" # icnv | Nlsv | clmv | Flwv
finder_default_search_scope = "SCcf" # SCcf = current folder
finder_show_all_files      = true
show_all_extensions        = true

# Keyboard
key_repeat             = 2
initial_key_repeat     = 15
press_and_hold_enabled = false

# Trackpad
trackpad_clicking = true
tap_to_click      = 1

# Screenshots
screenshot_location       = "$HOME/Desktop"
screenshot_type           = "png"
screenshot_disable_shadow = true

# Appearance
interface_style = "Dark" # Dark | Light
