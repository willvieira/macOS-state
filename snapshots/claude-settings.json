    "r-lib@posit-dev-skills": true,
    "shiny@posit-dev-skills": true,
    "quarto@posit-dev-skills": true,
    "understand-anything@understand-anything": true,
    "open-code-review@open-code-review": true
  },
  "extraKnownMarketplaces": {
